# MQTT配置
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=sensor/

# InfluxDB配置
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=sensor_data

# 通知渠道配置
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token
WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key
CUSTOM_WEBHOOK_URL=
CUSTOM_WEBHOOK_HEADERS={"Content-Type": "application/json"}

# 数据保留策略
DATA_RETENTION_DAYS=30
DATA_CLEANUP_INTERVAL=86400
AGGREGATION_INTERVAL=300

# 告警配置
ALERT_COOLDOWN=300
ALERT_ENABLED=true

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=mqtt_to_influxdb.log
