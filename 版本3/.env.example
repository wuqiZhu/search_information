# MQTT Configuration (board side)
MQTT_HOST=your_mqtt_broker_ip
MQTT_PORT=1883
MQTT_USERNAME=your_username
MQTT_PASSWORD=your_password
MQTT_CLIENTID=mqtt_bridge

# TLS Configuration (optional)
# Set to "1" or "true" to enable TLS encrypted connection
# When enabled, port will be changed to 8883 automatically
# MQTT_USE_TLS=1

# MQTT Configuration (cloud side — mqtt_to_influxdb.py)
# 云端的MQTT broker通常是 localhost（和脚本同机部署）
# MQTT_BROKER=localhost
# MQTT_PORT=1883
# MQTT_USER=zhuxiangbo
# MQTT_PASS=your_mqtt_password
# MQTT_TOPICS=device/response,device/telemetry,device/alert

# InfluxDB Configuration (cloud side)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token
INFLUXDB_ORG=your_org
INFLUXDB_BUCKET=your_bucket

# DingTalk Robot (cloud side)
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_token

# RPC Configuration (board side, optional)
RPC_HOST=127.0.0.1
RPC_PORT=1234
