# ===========================================
# 统一密钥管理 - 环境变量模板
# 复制此文件为 .env 并填入真实值
# ===========================================

# DeepSeek AI API
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.deepseek.com/v1

# 钉钉机器人
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token-here
DINGTALK_SECRET=your-secret-here

# 邮箱配置
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=your-email@qq.com
EMAIL_PASS=your-email-auth-code
EMAIL_TO=your-email@qq.com

# n8n 配置
N8N_PASSWORD=your-n8n-password
N8N_ENCRYPTION_KEY=your-encryption-key
DB_PASSWORD_N8N=your-db-password

# BestBlogs 配置
DB_PASSWORD_BESTBLOGS=your-db-password
REDIS_PASSWORD=your-redis-password
